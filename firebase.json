        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "l--artisan-dulce",
          "configurations": {
            "android": "1:719414434481:android:65d45cf92ec83a5c96a090",
            "ios": "1:719414434481:ios:03a9c61068926d2a96a090",
            "macos": "1:719414434481:ios:03a9c61068926d2a96a090",
            "web": "1:719414434481:web:91bc346bfb93d56996a090",
